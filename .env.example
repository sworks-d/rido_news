# RIDO News Agent - Environment Variables

# ============================================
# Supabase
# ============================================
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ============================================
# Discord
# ============================================
DISCORD_BOT_TOKEN=your_bot_token
DISCORD_CHANNEL_ALERT=your_alert_channel_id
DISCORD_CHANNEL_BRIEFING=your_briefing_channel_id
DISCORD_CHANNEL_DAILY=your_daily_channel_id
DISCORD_CHANNEL_STATUS=your_status_channel_id

# ============================================
# Server
# ============================================
PORT=3005

# ============================================
# Anthropic
# ============================================
ANTHROPIC_API_KEY=your_anthropic_api_key

# ============================================
# Discord Webhooks（Bot Tokenの代わりに使用）
# ============================================
DISCORD_WEBHOOK_ALERT=your_webhook_url
DISCORD_WEBHOOK_BRIEFING=your_webhook_url
DISCORD_WEBHOOK_DAILY=your_webhook_url
DISCORD_WEBHOOK_STATUS=your_webhook_url

# ============================================
# キャラクターアバター画像URL
# Discordにアップロードした画像のCDN URLを設定
# ============================================
AVATAR_GIREN=your_image_url
AVATAR_BRIGHT=your_image_url
AVATAR_ASTONAGE=your_image_url
AVATAR_BASK=your_image_url
AVATAR_KAI=your_image_url
AVATAR_AINA=your_image_url
AVATAR_GATO=your_image_url
AVATAR_AMURO=your_image_url
AVATAR_SHIRO=your_image_url
AVATAR_KOU=your_image_url
AVATAR_CHAR=your_image_url
AVATAR_MIRAI=your_image_url
